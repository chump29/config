{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "assist": {
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "useSortedAttributes": "on",
        "useSortedEnumMembers": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedPackageJson": "on",
        "useSortedProperties": "on",
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              "react",
              ":BLANK_LINE:",
              ":BUN:",
              ":BLANK_LINE:",
              "discord.js",
              ":BLANK_LINE:",
              "@postfmly/**",
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ":PATH:",
              ":BLANK_LINE:",
              ":STYLE:"
            ]
          }
        },
        "useSortedKeys": {
          "level": "on",
          "options": {
            "groupByNesting": true
          }
        }
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!bun.lock",
      "!!.pnpm-store",
      "!!.vscode",
      "!!**/*.html",
      "!!*coverage",
      "!!dist",
      "!!node_modules",
      "!!package.json",
      "!!tsconfig.json"
    ]
  },
  "formatter": {
    "expand": "always",
    "indentStyle": "space",
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "bracketSameLine": true,
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    },
    "globals": [
      "Bun"
    ]
  },
  "linter": {
    "domains": {
      "drizzle": "all",
      "project": "all",
      "react": "all",
      "test": "all",
      "types": "all"
    },
    "rules": {
      "preset": "all",
      "complexity": {
        "noDivRegex": "error",
        "noExcessiveCognitiveComplexity": "off",
        "noExcessiveLinesPerFunction": "off",
        "noImplicitCoercions": "error",
        "noRedundantDefaultExport": "error",
        "noUselessCatch": "error",
        "noUselessReturn": "error",
        "useArrayFind": "error"
      },
      "correctness": {
        "noNodejsModules": "off",
        "noSolidDestructuredProps": "off",
        "noUndeclaredDependencies": "off",
        "noUndeclaredVariables": "error",
        "noUnresolvedImports": "off",
        "noUnusedInstantiation": "error",
        "useJsonImportAttributes": "error",
        "useQwikValidLexicalScope": "off"
      },
      "nursery": {
        "noBaseToString": "error",
        "noComponentHookFactories": "error",
        "noConditionalExpect": "error",
        "noExcessiveNestedCallbacks": "error",
        "noIdenticalTestTitle": "error",
        "noImpliedEval": "error",
        "noJsxNamespace": "error",
        "noLoopFunc": "error",
        "noUndeclaredClasses": "error",
        "noUnnecessaryTemplateExpression": "error",
        "useDomNodeTextContent": "error",
        "useDomQuerySelector": "error",
        "useExpect": "error",
        "useExplicitType": "error",
        "useIframeSandbox": "error",
        "useImportsFirst": "error",
        "useIncludes": "error",
        "useMathMinMax": "error",
        "useReduceTypeParameter": "error",
        "useRegexpTest": "error",
        "useStringStartsEndsWith": "error",
        "useTestHooksInOrder": "error",
        "useThisInClassMethods": "error",
        "useVarsOnTop": "error"
      },
      "performance": {
        "noAwaitInLoops": "error",
        "noBarrelFile": "error",
        "noDelete": "error",
        "noJsxPropsBind": "error",
        "noNamespaceImport": "error",
        "noReExportAll": "error",
        "noSyncScripts": "error",
        "useSolidForComponent": "off",
        "useTopLevelRegex": "error"
      },
      "security": {
        "noSecrets": "off"
      },
      "style": {
        "noCommonJs": "error",
        "noDefaultExport": "off",
        "noExcessiveLinesPerFile": "off",
        "noExportedImports": "error",
        "noImplicitBoolean": "off",
        "noIncrementDecrement": "off",
        "noInferrableTypes": "off",
        "noJsxLiterals": "off",
        "noMagicNumbers": "error",
        "noMultilineString": "error",
        "noNamespace": "error",
        "noProcessEnv": "off",
        "noTernary": "off",
        "noUnusedTemplateLiteral": "error",
        "useAsConstAssertion": "error",
        "useConsistentEnumValueType": "error",
        "useConsistentMethodSignatures": "error",
        "useDestructuring": "error",
        "useErrorCause": "error",
        "useFilenamingConvention": "off",
        "useGlobalThis": "error",
        "useNamingConvention": "off",
        "useNumericSeparators": "error",
        "useSpreadOverApply": "error",
        "useExportType": {
          "level": "error",
          "options": {
            "style": "inlineType"
          }
        },
        "useImportType": {
          "level": "error",
          "options": {
            "style": "inlineType"
          }
        }
      },
      "suspicious": {
        "noDuplicatedSpreadProps": "error",
        "noEmptyBlockStatements": "error",
        "noEqualsToNull": "error",
        "noForIn": "error",
        "noLeakedRender": "error",
        "noNestedPromises": "error",
        "noReactSpecificProps": "off",
        "noUnknownAttribute": "error",
        "noUnnecessaryConditions": "error",
        "useArraySortCompare": "error",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": [
              "dir",
              "error",
              "groupCollapsed",
              "groupEnd",
              "info",
              "table"
            ]
          }
        }
      }
    }
  },
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true
  }
}
