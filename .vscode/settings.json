{
  "biome.configurationPath": "./biome.json",
  "biome.lsp.bin": "./node_modules/@biomejs/biome/bin/biome",
  "biome.suggestInstallingGlobally": false,
  "cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 3000,
  "css.lint.unknownAtRules": "ignore",
  "editor.detectIndentation": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "js/ts.experimental.useTsgo": true,
  "js/ts.preferences.importModuleSpecifier": "relative",
  "python.analysis.autoSearchPaths": false,
  "python.analysis.typeCheckingMode": "standard",
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/bin/python",
  "python.envFile": "${workspaceFolder}/backend/.env",
  "python.terminal.activateEnvironment": true,
  "python.terminal.useEnvFile": true,
  "terminal.integrated.scrollback": 10000,
  "todo-tree.highlights.enabled": false,
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^[ \\t]*(-|\\d+.)).*($TAGS)",
  "todo-tree.ripgrep.ripgrep": "/usr/bin/rg",
  "[css][dockercompose][javascript][javascriptreact][json][jsonc][typescript][typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[csv]": {
    "editor.defaultFormatter": "csvlinter.csvlinter-vscode"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "SashaBusinaro.yaml-compose-sorter"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[github-actions-workflow][yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "darkriszty.markdown-table-prettify"
  },
  "[nginx]": {
    "editor.defaultFormatter": "ahmadalli.vscode-nginx-conf"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[sh]": {
    "editor.defaultFormatter": "timonwong.shellcheck"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "better-comments.tags": [
    {
      "background": "transparent",
      "color": "#a6192e",
      "tag": "!"
    },
    {
      "background": "transparent",
      "color": "#0057b8",
      "tag": "?"
    },
    {
      "background": "transparent",
      "color": "#474747",
      "tag": "//"
    },
    {
      "background": "transparent",
      "color": "#ff9900",
      "tag": "todo"
    },
    {
      "background": "transparent",
      "color": "#04b34f",
      "tag": "*"
    }
  ],
  "black-formatter.args": [
    "--line-length=120"
  ],
  "coverage-gutters.coverageFileNames": [
    "lcov.info"
  ],
  "cSpell.import": [
    "${workspaceFolder}/.vscode/cspell.json"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.formatDocument": "explicit"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "support.type.property-name.table",
        "settings": {
          "foreground": "#4ec9b0"
        }
      },
      {
        "scope": "support.type.property-name.array",
        "settings": {
          "foreground": "#569cd6"
        }
      },
      {
        "scope": "constant.other.time",
        "settings": {
          "foreground": "#dcdcaa"
        }
      },
      {
        "scope": "string.quoted",
        "settings": {
          "foreground": "#ce9178"
        }
      }
    ]
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true
  },
  "isort.args": [
    "--profile",
    "black"
  ],
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev/schemas/latest/": true,
    "https://html-validate.org/schemas/": true,
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/": true
  },
  "markdownlint.config": {
    "MD013": {
      "line_length": 120
    },
    "MD026": {
      "punctuation": ".,;!"
    },
    "MD033": {
      "allowed_elements": [
        "img",
        "sup"
      ]
    }
  },
  "python.analysis.include": [
    "backend/**/*.py"
  ],
  "shellcheck.customArgs": [
    "-x"
  ],
  "todo-tree.filtering.excludeGlobs": [
    "**/.vscode/settings.json",
    "**/TODO.md"
  ],
  "todo-tree.general.tags": [
    "TODO"
  ]
}
