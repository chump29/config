#!/usr/bin/env -S bash -e

_project=$(git rev-parse --show-toplevel)
_from=~/.npm/node_modules/$(basename "$_project")
_to=$_project/node_modules

if [ ! -d "$_from" ]; then
  echo -e "📁 Creating $_from...\n"
  mkdir -p "$_from"
fi

if [ ! -d "$_to" ]; then
  echo -e "📁 Creating $_to...\n"
  mkdir -p "$_to"
fi

if ! findmnt "$_to" > /dev/null; then
  echo -e "▶️  Mounting node_modules...\n"
  sudo mount --bind "$_from" "$_to"
fi

findmnt "$_to"

echo -e "\n✅ node_modules is mounted"
