{
  "name": "@postfmly/config",
  "version": "1.4.24",
  "description": "Configuration files",
  "keywords": [
    "config"
  ],
  "homepage": "https://github.com/chump29/config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/config.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "bin": {
    "link-configs": "bin/link-configs"
  },
  "files": [
    ".vscode/",
    "biome.json",
    "bin/",
    "tsconfig.json"
  ],
  "scripts": {
    "clean": "rm bun.lock",
    "lint": "bun run scan && bun run lint:spell && bun run lint:biome",
    "lint:biome": "bun run --bun biome check --write --verbose --error-on-warnings",
    "lint:spell": "bun run --bun cspell --dot --verbose .",
    "scan": "bun run --bun cve-lite"
  },
  "peerDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "latest",
    "cspell": "^10.0.1",
    "cve-lite-cli": "^1.25.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true
}
